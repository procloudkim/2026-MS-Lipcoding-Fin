# 하루 오토파일럿 환경 변수 예시 (실제 secret은 커밋하지 않음)

# Express 포트 (Azure App Service는 PORT를 자동 주입)
PORT=3000

# Copilot SDK가 사용할 모델 이름 ('auto' = Copilot이 자동 선택)
COPILOT_MODEL=auto

# Copilot SDK 응답 타임아웃(ms). 초과 시 결정적 fallback으로 전환.
SDK_TIMEOUT_MS=20000

# (로컬에서 source=copilot-sdk 재현용) 비대화식 서버 인증용 GitHub 토큰.
# 설정 시 SDK가 로그인 사용자 대신 토큰으로 인증한다(서버/클라우드 구동용).
# 로컬: `gh auth token` 값. Azure: App Setting으로 주입(커밋 금지).
# COPILOT_GH_TOKEN=ghu_xxx

# (로컬에서 source=copilot-sdk 재현용) Copilot CLI 런타임 경로.
# node_modules에 @github/copilot 가 없거나 자동탐색이 실패할 때, 설치된 Copilot CLI
# 실행 파일을 가리키면 SDK가 해당 런타임을 spawn 한다.
# 예) Windows winget: copilot.exe / macOS·Linux: copilot 바이너리 경로.
# (미설정 시 server.js의 resolveCliPath()가 node_modules에서 자동 탐색)
# COPILOT_CLI_PATH=C:\\Users\\<you>\\AppData\\Local\\Microsoft\\WinGet\\Packages\\GitHub.Copilot_*\\copilot.exe

# (선택) Copilot CLI 런타임 경로.
# @github/copilot 가 로컬 node_modules에 없을 때, 설치된 Copilot CLI 실행 파일을 가리키면
# SDK가 해당 런타임을 spawn 한다. 예) Windows winget 설치 경로의 copilot.exe
# COPILOT_CLI_PATH=C:\\Users\\<you>\\AppData\\Local\\Microsoft\\WinGet\\Packages\\GitHub.Copilot_*\\copilot.exe
